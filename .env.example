# Copie para `.env` e preencha localmente. Nunca commit do `.env`.
APP_ENV=development
LOG_LEVEL=debug

# Auth
JWT_SECRET=__set_via_vault__
SESSION_TIMEOUT_MIN=30

# Banco
DATABASE_URL=postgres://user:pass@localhost:5432/app

# Observabilidade
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_SINK=stdout

# Telas obrigatórias
LOGS_API_RBAC_ROLES=admin,operator
MANUAL_FEEDBACK_TOPIC=manual.feedback
